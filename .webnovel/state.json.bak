    "qing_shizhu": {
      "id": "qing_shizhu",
      "type": "物件",
      "canonical_name": "青石柱",
      "tier": "装饰",
      "desc": "沈家别院廊下的老青石柱。沈安每日倚靠的位置，柱身上有一道被后背蹭了两年磨出的浅痕，石面光滑如水。沈安借此感知地脉气机走向与天痕之脉。第4章沈青萝观察到柱子气机律动在不同时辰受阳光影响不同。第10章沈安离开后知道浅痕正被晨光照着。",
      "first_appearance": 2,
      "last_appearance": 11
    },
