  "plot_threads": {
    "active_threads": [
      {
        "id": "thread_01",
        "name": "逐出令之谜",
        "type": "主线索",
        "description": "三年前沈安被逐出令所涉，因沈怀远打翻茶盏令纸被茶汤浸毁，逐出令至今未执行。沈安名字仍干净躺在副册上——浸毁的令纸压在案牍堆中，茶渍已干三年。第6章沈怀远回族谱阁确认名字尚在。第7章沈崇武当面施压暗示后，沈怀远锁上逐出名册。",
        "first_chapter": 1,
        "status": "active"
      },
      {
        "id": "thread_02",
        "name": "族规之别的观察",
        "type": "暗线",
        "description": "抄录弟子通过翻查全族副册，发现被朱笔勾掉的名字全在卷尾三册「旁支·逐出」中——签条十二年前沈崇武上任时贴上去的，被勾掉的名字无一人出自十二长老房头。第5章沈青萝独立发现同一规律——被逐者长辈无一人担任要职。",
        "first_chapter": 1,
        "status": "active"
      },
      {
        "id": "thread_03",
        "name": "沈崇武的压力收紧",
        "type": "对抗线",
        "description": "沈崇武通过族报训词逐步施压：上月「不可不察」→第3章「当及早戒」→第6章「荒嬉误族，当及早戒」。第5章沈青萝整理十二年演变表——从「勉族中子弟勤修不辍」到「及早戒」，措辞每年逼近。第7章亲自到戒律堂当面施压——「有些事不是非要摆在台面上才算数的。」",
        "first_chapter": 1,
        "status": "active"
      },
      {
        "id": "thread_04",
        "name": "矿脉、影阁与道痕体质",
        "type": "支线索",
        "description": "第3章沈怀远计划赴矿脉。第6章实际调查：星汉阁周天星痕航线抢光铁脊七矿点货运→铁氏往影阁倾销矿石换短期资金→影阁在黑市打听道痕亲和体质。三件事之间的关联让沈怀远决定立即送走沈安。",
        "first_chapter": 4,
        "status": "active"
      },
      {
        "id": "thread_05",
        "name": "沈青萝的调查",
        "type": "人物驱动线",
        "description": "第4-5章：天才少女沈青萝发现沈安排名反常后开始系统观察，用日轨图量化揭示其隐藏实力远超表面。观察被沈安反利用做自我校验后发现两人在暗中对弈。第5章查出族谱规律与沈崇武十二年措辞演变表，决定拿日轨图找沈怀远摊牌——因为她发现三年前打翻茶盏的正是沈怀远。",
        "first_chapter": 5,
        "status": "active"
      },
      {
        "id": "thread_06",
        "name": "沈怀远送子入砥砺宗",
        "type": "情节推进线",
        "description": "第6章沈怀远做出决定送沈安入砥砺宗。第7章被沈崇武施压后确认必须送走。第8章翻铁骊旧信写请求信，深夜看亡妻牌位。第9章在大门口送别——咽回想说三年的话。第10章沈安到达砥砺宗山门与铁骊初见。第一章卷完结。",
        "first_chapter": 7,
        "status": "resolved"
