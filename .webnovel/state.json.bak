    "family": {
      "father": "沈怀远",
      "father_role": "沈氏戒律长老",
      "mother": "早逝（沈安满月时从玄霄旧宅带来一块青石，放在儿子枕边说「这是你出生的地方。记住。」）",
      "father_relation": "沉默的守护者。三年前故意打翻茶盏浸毁逐出令。借「描红退步」为由与沈安过招被枯枝击败后形成父子沉默默契——「以后在外人面前别用树枝」「那用什么」「什么都不用」。第6章确认所有压力关联到沈崇武后决定送沈安入砥砺宗。第7章被沈崇武当面施压后锁上逐出名册。第8章深夜看亡妻牌位、翻出三年前铁骊旧信，写信请求收纳沈安。第9章在大门口送别时把真正想说的话咽回去——「我也忘了。」"
    },
    "key_characters": {
      "xiao_changhe": {
        "name": "萧长河",
        "role": "前世兄弟，被妻子苏锦年拿捏的妻管严",
        "relation": "在找沈溪风问清真相"
      },
      "su_jinnian": {
        "name": "苏锦年",
        "role": "萧长河之妻，暗线核心。因恐惧纪元更迭后修为归零而布局，表面上是在操纵所有人，实际被自己的恐惧操纵了一生，结局阴差阳错救了所有人。",
        "relation": "制造误会的始作俑者，但本意并非害人"
      },
      "xuntian_jian": {
        "name": "巡天鉴",
        "role": "萧长河的仙器，有独立器灵",
        "relation": "奉命扫描苍渊找沈溪风"
      },
      "jian_lao": {
        "name": "鉴老",
        "role": "巡天鉴器灵",
        "relation": "被沈溪风用黑历史威胁+贿赂，暗中帮忙"
      },
      "shen_shou_zhuo": {
        "name": "沈守拙",
        "role": "沈氏族中老实人",
        "relation": "比武中被沈溪风无意击败后被冤枉假斗，暗中知道沈溪风实力"
      },
      "shang_hen": {
        "name": "拭痕",
        "role": "沈溪风前世仙器，器灵在二十三连败的酒桌赌局中被迫认沈溪风为\"爹\"。",
        "relation": "被沈溪风以\"醉卧九天\"（编造的功法名）骗入沉睡并封印。中期梦境借力，后期苏醒。借力时沈溪风会嘴瓢/青笔印/酒嗅/引力紊乱。"
      },
      "li_huai": {
        "name": "厉淮",
        "role": "玄霄天律司第七执事，奉命追捕沈溪风。曾受沈溪风救命之恩。",
        "relation": "表面威严追捕，内心拼命放水。被勤奋的下属搞得骑虎难下。中期转为盟友。"
      },
      "tie_li": {
        "name": "铁骊",
        "role": "砥砺宗宗主。笔锋硬得像拳头砸出来的。宗训一个'磨'字。三年前给沈怀远写信——「他日若有难处，砥砺宗不欠沈家一个位置。」",
        "relation": "收到沈怀远请求后接纳沈安。见面第一句话：一个月磨不动退回沈家。但说这话时按住衣角掩饰握拳——他在期待沈安不好磨。表面严厉实则满怀期待。 第11-20章：从暗中观察到深度认知——发现沈安不需要被磨需要被理解。将沈安石板锁入核心弟子柜。第20章写信给沈怀远称'怀远兄'。"
      },
      "qing_luo": {
        "name": "沈青萝",
        "role": "沈氏年轻一代天才少女，窥痕境·明痕，沈崇武孙女",
        "relation": "第4章开始系统观察沈安，用日轨图记录其行为数据。发现沈安道痕感知精度超刻痕境六倍。观察被沈安反向利用做自我校验。第5章查出族谱规律与沈崇武措辞演变表，决定拿日轨图找沈怀远摊牌。"
      },
      "wen_xiaolu": {
        "name": "温小鹿",
        "role": "砥砺宗二师姐，实际最强弟子",
        "relation": "与沈安是沉默同盟——两人共处一室两个时辰不说一个字，全宗管这叫约会。 第17章与沈安在经籍阁两个时辰零交流——全宗管这叫沉默约会。在桌角留下最好的暗青色道痕矿石。连名字都没互相说过。"
      },
      "yun_du": {
        "name": "云渡",
        "role": "渡舟人少女",
        "relation": "唯一明确喜欢沈安的人。表达方式：送发光石头、法则枯叶、活鱼。"
      },
      "lu_chuan": {
        "name": "陆川",
        "role": "星汉阁创始人",
        "relation": "原砥砺宗弟子，被铁骊赶走后创立星汉阁，飞舟行业颠覆者。"
      },
      "ji_qiuying": {
        "name": "纪秋萤",
        "role": "青石学宫女弟子，被包装的\"道痕天才\"",
        "relation": "青石学宫造星事件的被包装者，事件后被遗忘。"
      },
      "zhou_gong": {
        "name": "周宫主",
        "role": "青石学宫第三代宫主",
        "relation": "为维持学宫运转包装纪秋萤，成功后不敢面对真相。"
      },
      "chaolu_dizi": {
        "name": "族谱抄录弟子",
        "role": "沈氏族谱阁轮值弟子，功能性POV角色",
        "relation": "已在阁中两年，日常抄谱、补页、勾名字。发现副册规律——被朱笔勾掉的名字无一人出自十二长老房头。在竹册末页写下「族规对人有别」。"
      },
      "lao_shuli": {
        "name": "老书吏",
        "role": "沈氏族谱阁老书吏",
        "relation": "在阁中数十年（没人记得清是四十年还是六十年）。对抄录弟子的疑问只回了一句「朱墨别研太满。省墨。」——看似冷淡实则保护。第3章结尾与沈怀远简短对话，沈怀远不知其属于哪类人。第6章沈怀远再访族谱阁时对望无言。"
      },
      "shen_huaiyuan": {
        "name": "沈怀远",
        "role": "沈氏戒律长老，沈安之父",
        "relation": "三年前打翻茶盏借茶汤浸毁逐出令。第3章首次内心世界全景曝光：对族规执行不公深感自我分裂，枯枝被击败后形成父子沉默默契。第6章决定送沈安入砥砺宗。第7章被沈崇武当面施压后锁上逐出名册。第8章翻铁骊旧信、看亡妻牌位、深夜远处望沈安。第9章在大门口送别——咽回想了三年的话。"
      },
      "shen_chongwu": {
        "name": "沈崇武",
        "role": "沈氏大长老，卷1主要对手",
        "relation": "掌控沈氏十二长老体制的核心人物。第7章亲自找沈怀远\"喝茶\"施压——「有些事不是非要摆在台面上才算数的。」"
      }
