  "entities": {
    "chaolu_dizi": {
      "id": "chaolu_dizi",
      "type": "角色",
      "canonical_name": "族谱抄录弟子",
      "tier": "装饰",
      "desc": "沈氏族谱阁轮值弟子，已在阁中两年，日常三件事：抄谱、补页、勾名字。发现族谱规律——副册上被朱笔勾掉的名字无一人出自十二长老房头。在自用竹册末页写下「族规对人有别」。曾差点忍不住替沈安勾名——朱笔提起来离纸面半寸又放下——因为老书吏说「朱墨别研太满」。",
      "first_appearance": 1,
      "last_appearance": 7
    },
    "lao_shuli": {
      "id": "lao_shuli",
      "type": "角色",
      "canonical_name": "老书吏",
      "tier": "装饰",
      "desc": "沈氏族谱阁老书吏，在阁中干了数十年（没人记得清是四十年还是六十年）。坐在偏殿后小隔间修旧谱补笔管。对抄录弟子的疑问只回了一句「朱墨别研太满。省墨。」——看似冷淡实则保护。第3章结尾沈怀远与其简短对话——叫长老不加姓氏，暗示其地位特殊。第6章沈怀远再来族谱阁时两人无声对望。",
      "first_appearance": 1,
      "last_appearance": 7
    },
    "shen_huaiyuan": {
      "id": "shen_huaiyuan",
      "type": "角色",
      "canonical_name": "沈怀远",
      "tier": "重要",
      "desc": "沈氏戒律长老，沈安之父。第3章首次以其内心视角全景曝光：身居戒律长老之位却对族规执行不公深感自我分裂；三年前故意打翻茶盏浸毁逐出令。第6章确认沈崇武压力与矿脉影阁异常后决定送沈安入砥砺宗。第7章被沈崇武当面施压后锁上逐出名册。第8章翻旧信写请求信，深夜看亡妻牌位。第9章在大门口送别沈安——把真正想说的话咽回去：「我也忘了。」",
      "first_appearance": 1,
      "last_appearance": 21
    },
    "shen_chongwu": {
      "id": "shen_chongwu",
      "type": "角色",
      "canonical_name": "沈崇武",
      "tier": "重要",
      "desc": "沈氏大长老，卷1主要对手。掌控沈氏十二长老体制的核心人物。第3章：族报训词措辞从「不可不察」升级为「当及早戒」。第5章：沈青萝整理其十二年族报标题措辞演变表。第7章：亲自找沈怀远「喝茶」施压——「有些事不是非要摆在台面上才算数的。」临走前扫了一眼卷宗室方向。",
      "first_appearance": 1,
      "last_appearance": 8
    },
    "shen_an": {
      "id": "shen_an",
      "type": "角色",
      "canonical_name": "沈安",
      "tier": "主角",
      "desc": "玄霄巅峰大佬假死逃到苍渊，当戒律长老的躺平儿子。第2章首次以直接视角出场：倚靠青石柱感知地脉气机，仅凭振动回响/笔迹余温精准解读周遭人事。第3章揭示三岁即可感知地下道痕矿脉。第4-5章被沈青萝系统观察并反利用其观测做自我校验。第9章被父亲送到门口，告别时拆穿父亲每一层伪装。第10章走三天山路到达砥砺宗——前世布下的天痕之脉种子已长成覆盖全苍渊的感知网络。",
      "first_appearance": 1,
      "last_appearance": 22
    },
    "lao_sun": {
      "id": "lao_sun",
      "type": "角色",
      "canonical_name": "老孙",
      "tier": "装饰",
      "desc": "沈氏撞钟人。儿子在矿上捡了块石头（非灵石但儿子坚信是），每晚放在枕边。因心中多了不确定的事，晨钟经常晚半刻。酒后撞钟。走路五十二步从钟楼脚到撞木位。",
      "first_appearance": 2,
      "last_appearance": 2
    },
    "zupu_fuce": {
      "id": "zupu_fuce",
      "type": "物件",
      "canonical_name": "族谱副册",
      "tier": "装饰",
      "desc": "沈氏三百年族谱——正册十二卷记主脉，副册六十余卷记旁支。卷尾三册签条「旁支·逐出」，十二年前沈崇武上任后贴上去的，此后被朱笔勾掉的名字全在这三册里。沈安的名字至今干干净净躺在四房副册第七页——朱笔该落未落已三年。三年未执行的浸毁逐出令纸压在案牍堆中。",
      "first_appearance": 1,
      "last_appearance": 7
    },
    "zupu_ge": {
      "id": "zupu_ge",
      "type": "地点",
      "canonical_name": "族谱阁",
      "tier": "装饰",
      "desc": "沈家祠堂东面的偏殿。三面墙排满黑檀木格，码着沈氏三百年族谱。轮值弟子在此抄谱、补页、勾名字。后面有小隔间，老书吏常年在此修旧谱补笔管。案牍堆下压着三年前被茶汤浸毁至今未执行的逐出令纸。",
      "first_appearance": 1,
      "last_appearance": 7
    },
    "zhubi": {
      "id": "zhubi",
      "type": "物件",
      "canonical_name": "朱笔",
      "tier": "装饰",
      "desc": "族谱阁专用的朱砂笔，用于勾销逐出子弟的名字。要求：力道匀，墨不能多（多了浸下一页）不能少（少了像没勾干净）。一眼看过去就知道这个名字废了。抄录弟子每日研好朱墨，等大执事宣读逐出令。",
      "first_appearance": 1,
      "last_appearance": 2
