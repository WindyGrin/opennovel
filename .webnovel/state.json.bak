    },
    "feizhou_hangxian": {
      "id": "feizhou_hangxian",
      "type": "物件",
      "canonical_name": "飞舟航线",
      "tier": "装饰",
      "desc": "铁脊山脉的飞舟货运航线，沈氏与砥砺宗、星汉阁竞争的大宗运输通道。第3章提及星汉阁抢了沈氏一单大宗运单。第6章星汉阁「周天星痕」航线已抢光七矿点全部货运。",
      "first_appearance": 4,
      "last_appearance": 7
    },
    "jielv_tang": {
      "id": "jielv_tang",
      "type": "势力",
      "canonical_name": "戒律堂",
      "tier": "装饰",
      "desc": "沈氏族内执掌戒律的机构，沈怀远任戒律长老。每月逐出弟子名册由其管理，但族规的执行力度对不同房头并不平等——主脉弟子从未出现在逐出名册上。第7章沈崇武在此与沈怀远「喝茶」。",
      "first_appearance": 4,
      "last_appearance": 8
    },
    "zu_bao": {
      "id": "zu_bao",
      "type": "物件",
      "canonical_name": "沈氏族报",
      "tier": "装饰",
      "desc": "沈氏内部传讯用族报，头版照例为沈崇武训词。第3章训词措辞从「不可不察」升级为「当及早戒」。第5章沈青萝整理十二年标题演变表。第6章训词再升级为「荒嬉误族，当及早戒」。",
      "first_appearance": 2,
      "last_appearance": 7
    },
    "qing_luo": {
      "id": "qing_luo",
      "type": "角色",
      "canonical_name": "沈青萝",
      "tier": "重要",
      "desc": "沈氏年轻一代唯一窥痕境·明痕，十七岁破境比同龄人早至少五年，沈崇武孙女。第4章在族会发现沈安缺席后开始系统观察——用日轨图和竹简记录其行为数据，发现其非休息而是进行极高精度的被动道痕感知（精度超刻痕境六倍）。观察被沈安反向利用做自我校验后不怒反笑——「我终于知道自己在跟谁下棋了。」第5章整理沈崇武十二年族报措辞演变表，发现「及早戒」三个字写了十二年。决定拿日轨图找沈怀远摊牌。",
      "first_appearance": 5,
      "last_appearance": 6
    },
    "rigui_tu": {
      "id": "rigui_tu",
      "type": "物品",
      "canonical_name": "日轨图",
      "tier": "装饰",
      "desc": "沈青萝自创的环形时间分析图。十二时辰均分一圈，每个观察节点标注状态变化。用于系统研究沈安的日常行为规律——三天十二个标记点，每个点附推导公式。用画阵图的方法画一个人的日常轨迹。后续成为家族会议上揭露沈安隐藏实力的关键物证。",
      "first_appearance": 6,
      "last_appearance": 6
    },
    "lao_huaishu": {
      "id": "lao_huaishu",
      "type": "地点",
      "canonical_name": "老槐树",
      "tier": "装饰",
      "desc": "沈家后院角落一棵两人合抱不住的老槐树。树皮上有一道刻痕——离地三尺半，十七年前沈怀远发现三岁沈安感知到地下道痕矿脉后所刻。十七年后刻痕已被树皮翻卷包进一半。树下有一个被人工填过、每一铲都踩实压紧的土坑——沈怀远掩盖证据的痕迹。第4章沈青萝经过时注意到土坑并记住。",
      "first_appearance": 2,
      "last_appearance": 5
    },
    "houyuan_kuangmai": {
      "id": "houyuan_kuangmai",
      "type": "物件",
      "canonical_name": "后院道痕矿脉",
      "tier": "装饰",
      "desc": "沈家后院地下四尺深处隐藏的一条道痕矿脉。灰青色矿石，色泽比沈家矿上最好的矿还浓三分。脉的走向偏西南——完全不在沈氏已有的矿脉图上。十七年前被三岁沈安感知到，沈怀远挖出后重新填埋掩盖。",
      "first_appearance": 2,
      "last_appearance": 2
    },
    "xuanxiao_qingshi": {
      "id": "xuanxiao_qingshi",
      "type": "物件",
      "canonical_name": "玄霄青石",
      "tier": "装饰",
      "desc": "拳头大小青石，表面粗粝，断面泛暗青色光。沈安满月那天沈怀远从玄霄旧宅带来——沈安母亲还活着时放在儿子枕边说：「这是你出生的地方。记住。」第8章沈怀远从木格取出握在手里站了很久。石头还在，人没了。",
      "first_appearance": 9,
      "last_appearance": 9
    },
    "shen_an_muqin": {
      "id": "shen_an_muqin",
      "type": "角色",
      "canonical_name": "沈安亡母",
      "tier": "装饰",
      "desc": "沈安的母亲，早逝。沈家对早逝的媳妇只留一个位置不刻全名。生前说过：「我走了以后你别跪。你一跪腿就软了。腿软了就站不住。」——沈怀远此后真的一直没跪。第8章沈怀远深夜站在她牌位前到子时。",
      "first_appearance": 9,
      "last_appearance": 9
    },
    "tie_li": {
      "id": "tie_li",
      "type": "角色",
      "canonical_name": "铁骊",
      "tier": "重要",
      "desc": "砥砺宗宗主。笔锋硬得像拳头砸出来的。宗训一个字：磨。三年前给沈怀远写信——「他日若有难处，砥砺宗不欠沈家一个位置。」第8章沈怀远翻出此信。第10章站在山门直道尽头审视沈安，第一句话：「一个月。磨不动——退回沈家。」但说这话时按住衣角掩饰握拳冲动——他在期待沈安不好磨。第22章六页质问被沈安用宗规原文一击瓦解——三十年前亲手抄入章程的'不强制'三字反过来否定了她三十年建立的默认体系。",
      "first_appearance": 9,
      "last_appearance": 22
    },
    "dilizong_shanmen": {
      "id": "dilizong_shanmen",
      "type": "地点",
      "canonical_name": "砥砺宗山门",
      "tier": "装饰",
      "desc": "砥砺宗入口——两块一人半高原石夹一张铁匾，匾上只刻一字：「磨」。铁骊题的字，笔锋硬得像用拳头砸出来的。门内碎石直道尽头石壁上密密麻麻全是历代弟子描红训练刻痕——每一道入石至少半分。",
      "first_appearance": 11,
      "last_appearance": 11
    },
    "yinge": {
      "id": "yinge",
      "type": "势力",
      "canonical_name": "影阁",
      "tier": "装饰",
      "desc": "苍渊情报交易之络。第6章铁氏暗地向影阁大量倾销矿石换短期资金，影阁在黑市打听道痕亲和体质——引起沈怀远警觉。",
      "first_appearance": 7,
      "last_appearance": 21
    },
    "kuangshang_laojiangong": {
      "id": "kuangshang_laojiangong",
      "type": "角色",
      "canonical_name": "矿上老监工",
      "tier": "装饰",
      "desc": "沈氏矿脉老监工。第6章向沈怀远透露铁氏往影阁倾销矿石，并说出不该说的话——「有人在黑市上打听道痕亲和体质。」",
      "first_appearance": 7,
      "last_appearance": 7
    },
    "tie_siyuan": {
      "id": "tie_siyuan",
      "type": "角色",
      "canonical_name": "铁思源",
      "tier": "装饰",
      "desc": "砥砺宗核心弟子，铁骊今年初内部评语'尚可打磨'。站姿标准但肩膀僵硬——站位来自被包装的标准而非天赋。对沈安说'你最好早点被淘汰'——真心担忧铁骊需写信退人。与沈崇武用了同一块'维持我是标准'的肌肉。",
      "first_appearance": 13,
      "last_appearance": 13
    },
    "jiandu_shixiong": {
      "id": "jiandu_shixiong",
      "type": "角色",
      "canonical_name": "监督师兄",
      "tier": "装饰",
      "desc": "砥砺宗第五期弟子，监督每日晨练并记录日志。当了三年监督师兄第一次在日志上写'异'字。发现沈安是精确控制而非偷懒后重新理解描红意义。第19章对铁骊说出'为什么这本书不是铁骊写的'。",
      "first_appearance": 15,
      "last_appearance": 20
    },
    "shaizi": {
      "id": "shaizi",
      "type": "角色",
      "canonical_name": "筛子",
      "tier": "装饰",
      "desc": "后山采石人，黑市代号'筛子'。影阁在矿区挑矿样的线人。捡石方式特殊——按光照逆向筛选，留石块在阳光最先照到处。第20章收到从虚海运来的黑石，上刻影阁标记——包裹投递正式开始。沈怀远早已背下其捡石路线。",
      "first_appearance": 12,
      "last_appearance": 21
    },
    "dinghao_she": {
      "id": "dinghao_she",
      "type": "地点",
      "canonical_name": "丁号修炼舍",
      "tier": "装饰",
      "desc": "砥砺宗最西端偏远处修炼舍，专给观察期新人和快被淘汰者。四张矮床四份描红套装，空置半年以上。窗外灰岩柱基座在第七枢点支脉流线上，床铺下方有支脉分岔穿过。",
      "first_appearance": 12,
      "last_appearance": 21
    },
    "jingji_ge": {
      "id": "jingji_ge",
      "type": "地点",
      "canonical_name": "经籍阁",
      "tier": "装饰",
      "desc": "砥砺宗藏书处。最后一排旧案是温小鹿藏身处，后成她与沈安沉默同盟据点。藏有九年前被借过的《苍渊地脉道痕初步》《第七枢点论》《苍渊道痕气象学》等积灰道痕典籍。",
      "first_appearance": 17,
      "last_appearance": 18
    },
    "huiyan_zhu": {
      "id": "huiyan_zhu",
      "type": "物件",
      "canonical_name": "灰岩柱",
      "tier": "装饰",
      "desc": "丁号舍外廊道第三根灰岩支撑柱，基座在第七枢点支脉流线上，传导效率比青石柱低一成半但刚好够做被动观测。成为沈安在砥砺宗的新日常观测点。",
      "first_appearance": 12,
      "last_appearance": 21
    },
    "houshan_tieti": {
      "id": "houshan_tieti",
      "type": "地点",
      "canonical_name": "后山铁梯",
      "tier": "装饰",
      "desc": "砥砺宗后山铁制阶梯，通往矿渣区和采石场。沈安第一天即绕路至此观察采石人路线。铁骊从出入记录注意到此刻意行为并注'非随意行为'。",
      "first_appearance": 12,
      "last_appearance": 21
    }
  },
  "relationships": {
    "rel_01": {
      "from": "chaolu_dizi",
      "to": "lao_shuli",
      "type": "师徒/传承",
      "description": "抄录弟子发现副册规律后向老书吏请教，老书吏只回了一句「朱墨别研太满。省墨。」——不是在回答问题，是在教这个阁子里该怎么活着。三句话没有一句直接回答，每一句都在教怎么在这个阁子里活下去。",
      "first_chapter": 1
    },
    "rel_02": {
      "from": "shen_huaiyuan",
      "to": "shen_an",
      "type": "父子",
      "description": "戒律长老沈怀远与其独子沈安。三年前当众打翻茶盏保护儿子免于被逐出。第3章过招被枯枝击败后形成沉默默契——「以后在外人面前别用树枝」「那用什么」「什么都不用」。第3章揭示源头：三岁时沈安感知地下矿脉，沈怀远掩盖后告诫「不要跟任何人说」。第9章在大门口送别——咽回想说三年的话，换一句「到了那边别跟人动手」。沈安回头补一句：「爹。那只猫是人家隔壁的。你下次送人别再认错猫了。」——每句绕开，每句都懂。",
      "first_chapter": 1
    },
    "rel_03": {
      "from": "chaolu_dizi",
      "to": "shen_an",
      "type": "观察/共情",
      "description": "抄录弟子每次翻到沈怀远那一房的副册都会停下——沈安的名字静静躺在那一页上，下面没有朱笔痕迹，三年了朱笔该落未落。曾差点忍不住提朱笔替他勾名——笔尖离纸面半寸又放下。在竹册末页写下「族规对人有别」。",
      "first_chapter": 1
    },
    "rel_04": {
      "from": "shen_an",
      "to": "lao_sun",
      "type": "暗中感知",
      "description": "沈安通过震动与回响精确感知老孙的生活细节——撞钟晚了、走路步数、喝酒原因、儿子捡石头。老孙不知道有人能感知到这一切。整座青石城知道老孙秘密的只有三个人，沈安是第四个。",
      "first_chapter": 2
    },
    "rel_05": {
      "from": "shen_huaiyuan",
      "to": "lao_guanjia",
      "type": "默契",
      "description": "三年前茶盏事件后老管家从此倒茶永远把茶盏放在桌子正中间。第9章沈安走后端出热茶问沈怀远刚才想说什么——沈怀远答「我也忘了。」老管家知道的事比想说的多。",
      "first_chapter": 4
    },
    "rel_06": {
      "from": "shen_huaiyuan",
      "to": "shen_chongwu",
      "type": "对立/警惕",
      "description": "沈怀远深知所有看似无关之事最终都会关联到沈崇武。第7章沈崇武亲自来戒律堂「喝茶」施压——「有些事不是非要摆在台面上才算数的。」沈怀远在他走后锁上逐出名册，确认必须送走沈安。",
      "first_chapter": 4
    },
    "rel_07": {
      "from": "da_zhishi",
      "to": "shen_huaiyuan",
      "type": "配合/默契",
      "description": "三年前族会上宣读逐出令被茶汤浸毁后，大执事把令纸折了两次说「待明日再议」——给了沈怀远争取时间的空间。",
      "first_chapter": 4
    },
    "rel_08": {
      "from": "shen_huaiyuan",
      "to": "lao_shuli",
      "type": "微妙的尊重",
      "description": "第3章结尾沈怀远深夜赴族谱阁确认沈安名字尚在副册上，出门时与老书吏简短对话——「老师傅。」「笔管修好了。」「还没。差一圈线。」——叫长老不加姓氏。第6章沈怀远再来族谱阁看沈安名字时两人无声对望。",
      "first_chapter": 4
    },
    "rel_09": {
      "from": "qing_luo",
      "to": "shen_an",
      "type": "系统观察/研究→互相利用",
      "description": "第4章沈青萝从隐蔽位置系统观察沈安，用日轨图和竹简记录其日常行为数据，发现其表面懒散实则道痕感知精度超刻痕境六倍。放镜石测试后被沈安一眼识破——沈安不揭穿，反将她的观察当成免费第三方观测数据做自我校验。沈青萝不怒反笑——「我终于知道自己在跟谁下棋了。」第5章全面分析后决定拿日轨图找沈怀远摊牌。",
      "first_chapter": 5
    },
    "rel_10": {
      "from": "qing_luo",
      "to": "shen_chongwu",
      "type": "祖孙/观察者与被观察者",
      "description": "沈青萝是沈崇武的孙女，沈家年轻一代唯一窥痕境·明痕。第5章她进入沈崇武书房——观察到爷爷的书房不像书斋，像在时刻自我更新措辞的发布站。整理沈崇武十二年族报标题措辞演变表，发现「及早戒」三个字写了十二年——从贴「旁支·逐出」签条第一天开始。",
      "first_chapter": 6
    },
    "rel_11": {
      "from": "shen_huaiyuan",
      "to": "shen_an_muqin",
      "type": "夫妻（亡）",
      "description": "沈怀远与早逝的妻子。她留下的话——「我走了以后你别跪。你一跪腿就软了。腿软了就站不住。」——沈怀远一直没跪。第8章深夜站在她牌位前到子时，取出沈安满月时的玄霄青石。",
      "first_chapter": 9
    },
    "rel_12": {
      "from": "shen_huaiyuan",
      "to": "tie_li",
      "type": "旧交/托付",
      "description": "铁骊三年前给沈怀远写信——「他日若有难处，砥砺宗不欠沈家一个位置。」第8章沈怀远翻出此信，写短信恳请收纳管教沈安。明知沈崇武会同时写相反措辞的信。第10章铁骊果然收到两封信——见面第一句话「一个月。磨不动——退回沈家。」",
      "first_chapter": 9
    },
    "rel_13": {
      "from": "shen_an",
      "to": "tie_li",
      "type": "初见/审视",
      "description": "第10章沈安走到砥砺宗山门前与铁骊初见。铁骊说「一个月磨不动退回沈家」时按住衣角掩饰握拳——沈安一眼看穿他在期待自己不好磨。沈安只回了一个字：「好。」",
      "first_chapter": 11
    },
    "rel_14": {
      "from": "shen_an",
      "to": "dilizong_shanmen",
      "type": "到达/进入",
      "description": "第10章沈安走三天山路到达砥砺宗。山门前意识到脚下每一条山路都在前世布下的天痕之脉枢点上——全苍渊是他留下的地图。山门上铁骊题的一个'磨'字。",
      "first_chapter": 11
    },
    "rel_15": {
      "from": "shen_an",
      "to": "tie_li",
      "type": "被审视/被深度关注",
      "description": "第11-20章铁骊从第一天就在暗中观察沈安——出入记录一式两份，描红石单独编号，石板单独锁入核心弟子木柜。第十二天全宗石板对比后她终于明白：此人不需要被磨，需要被理解。在日志写下'理解他的代价——可能比我想要的更多。'",
      "first_chapter": 12
    },
    "rel_16": {
      "from": "shen_an",
      "to": "tie_siyuan",
      "type": "同门/微妙",
      "description": "沈安被铁思源领至丁号舍。从其站姿识别出对方是包装的标准而非天赋——每次维持'我是标准'用同一块肌肉，让沈安想起沈崇武。铁思源说'你最好早点被淘汰'——真心担忧而非嘲讽。",
      "first_chapter": 13
    },
    "rel_17": {
      "from": "shen_an",
      "to": "wen_xiaolu",
      "type": "沉默同盟",
      "description": "第17章两人在经籍阁旧案桌东西两端坐了两个时辰零交流。全宗称之为'沉默约会'。温小鹿在桌角留下一块暗青色道痕矿石——她最好的那块。沈安没拿。连名字都没互相说过。无需语言即理解彼此。",
      "first_chapter": 18
    },
    "rel_18": {
      "from": "shen_an",
      "to": "shaizi",
      "type": "暗中观察",
      "description": "沈安第一天就感应到后山采石人——通过脚步频率、弯腰节奏、碎石拨动声推断其在筛选矿石。第20章注意到筛子脚步比平时快了半步——被影阁包裹吓到。",
      "first_chapter": 12
    },
    "rel_19": {
      "from": "shen_an",
      "to": "jiandu_shixiong",
      "type": "引起注意/被研究",
      "description": "监督师兄是第一个系统评估沈安描红精度的人。从圈掉的问号到'异'字，最终对铁骊说'为什么这本书不是铁骊写的'——这句话触动了铁骊内心最深处。",
      "first_chapter": 15
    },
    "rel_20": {
      "from": "tie_li",
      "to": "shen_huaiyuan",
      "type": "通信/旧交",
      "description": "第20章铁骊写信称'怀远兄'——三十年通信中第二次用此称呼。信中详述沈安异常表现，末句提问'你当年在学宫是怎么跟这种人打交道的'。沈怀远读三遍后决定不回——回复即承认他送过去的不是磨不动的废物。",
      "first_chapter": 21
    },
    "rel_22": {
      "from": "shen_an",
      "to": "tie_li",
      "type": "权力翻转/认知颠覆",
      "description": "第22章铁骊六页质问围剿沈安的'刚好及格'。前三问沈安沉默，第四问起身从书架取下《砥砺宗宗规》，翻到第三卷附录第二节末句——'宗门不强制超量修炼'。铁骊三十年默认被自己亲手抄入章程的一行字瓦解。沈安翻书无需查找——从书脊到目标页零停顿。铁骊随后意识到：如果第一天把话问完，今天就不是她在问沈安，是沈安在问她。她把剩余两页问题锁进抽屉。",
      "first_chapter": 22
    }
  },
